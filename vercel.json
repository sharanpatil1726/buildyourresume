{
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/refresh-jobs", "schedule": "0 2 * * *" },
    { "path": "/api/cron/job-alerts",   "schedule": "30 2 * * *" }
  ]
}
